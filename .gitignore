# ──────────────────────────────────────────────
#  Спільний .gitignore для monorepo (frontend + backend)
# ──────────────────────────────────────────────

# Залежності
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Білди / згенероване
**/.next/
**/out/
**/build/
**/dist/
*.tsbuildinfo
next-env.d.ts

# Тестування / покриття
**/coverage/

# Змінні оточення (секрети!) — приклади залишаємо у git
.env
.env.*
!.env.example

# Завантажені користувачем файли (backend)
backend/uploads/

# Prisma — локальна БД, якщо колись з'явиться sqlite
*.db
*.db-journal

# Логи
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Редактори / ОС
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Сертифікати / ключі
*.pem

# Vercel
.vercel
